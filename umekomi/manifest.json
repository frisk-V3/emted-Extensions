{
  "manifest_version": 3,
  "name": "frisk-V3",
  "version": "1.3",
  "permissions": ["scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "index.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "frisk-v3@example.com",
      "data_collection_permissions": {
        "required": ["none"],
        "collected_data": ["none"]
      }
    }
  }
}
